    "ShortQuestions": [
        {
            "id": 1,
            "question": "Why fix warnings before shipping?",
            "preferredAnswer": "Warnings often indicate **future errors** or **deprecated APIs** that become **crashes** or **rejections** in production."
        },
        {
            "id": 2,
            "question": "What is the difference between unit and E2E tests?",
            "preferredAnswer": "**Unit** tests isolate **small** pieces (functions/components). **E2E** tests drive the **full app** like a user—slower but higher **confidence** on critical paths."
        },
        {
            "id": 3,
            "question": "Why read native logs with Xcode/logcat?",
            "preferredAnswer": "Some failures happen **below** JS (native crashes, linking)—JS stack traces alone miss **native** causes."
        },
        {
            "id": 4,
            "question": "Name one item on a release checklist besides code.",
            "preferredAnswer": "**Store metadata**, **privacy**, **analytics opt-in**, **rollback plan**, **support contact**, **feature flags**—operational readiness."
        },
        {
            "id": 5,
            "question": "Why is accessibility a release concern?",
            "preferredAnswer": "It affects **real users**, **App Store** expectations, and sometimes **legal** compliance—also improves **general UX** (larger tap targets, clarity)."
        }
    ]
