    "ShortQuestions": [
        {
            "id": 1,
            "question": "Why does React Native default flexDirection to column, unlike CSS flexbox on the web?",
            "preferredAnswer": "Mobile layouts are overwhelmingly **vertical**; column default matches common screen composition. Web often uses **row** nav bars; RN optimizes for **portrait** content stacks."
        },
        {
            "id": 2,
            "question": "When would you choose FlatList instead of ScrollView?",
            "preferredAnswer": "**FlatList** virtualizes rows and mounts only visible items—needed for **long or infinite** lists. **ScrollView** renders **all** children at once, which hurts performance for large lists."
        },
        {
            "id": 3,
            "question": "Explain flex: 1 on a child inside a flex container.",
            "preferredAnswer": "**flex: 1** makes the child **grow** to consume available space along the main axis within the parent’s constraints, sharing space with siblings according to flex rules."
        },
        {
            "id": 4,
            "question": "What problem does safe-area-context solve?",
            "preferredAnswer": "It applies **insets** so content is not hidden under **notches**, **status bars**, or **home indicators**, differing per device."
        },
        {
            "id": 5,
            "question": "Give one reason StyleSheet.create is preferred over inline style objects everywhere.",
            "preferredAnswer": "Centralized styles are easier to **maintain**, **reuse**, and **validate**; RN also documents slight performance benefits from registered styles versus recreating plain objects on every render in hot paths."
        }
    ]
}
