    "ShortQuestions": [
        {
            "id": 1,
            "question": "Why clean up intervals and subscriptions in useEffect?",
            "preferredAnswer": "Without cleanup, **listeners keep firing** after unmount, causing **memory leaks**, **setState on unmounted components**, and wasted battery."
        },
        {
            "id": 2,
            "question": "When should you avoid useMemo?",
            "preferredAnswer": "For **cheap** computations where dependency arrays add noise, or when memoization **hides** real performance issues in lists—**profile first**."
        },
        {
            "id": 3,
            "question": "How does AppState differ from web page visibility?",
            "preferredAnswer": "Mobile apps **suspend**, **background**, and **resume** with OS policies; timers and network may **pause**—you must **pause work** and **persist** state appropriately."
        },
        {
            "id": 4,
            "question": "Give an example of work to pause when the app backgrounds.",
            "preferredAnswer": "**Animations**, **polling**, **live location tracking**, or **active audio**—resume on `active` or save user progress."
        },
        {
            "id": 5,
            "question": "What is the purpose of the dependency array?",
            "preferredAnswer": "It tells React **when** to re-run the effect: when listed **values change**. Empty array means **mount-only**; omitted means **every render** (usually a bug)."
        }
    ]
