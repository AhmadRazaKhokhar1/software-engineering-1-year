    "ShortQuestions": [
        {
            "id": 1,
            "question": "Why is file-based routing attractive in Expo Router?",
            "preferredAnswer": "Routes are **discoverable from the filesystem**, less boilerplate than manually registering screens, and align with **URL-based** mental models for linking and web parity."
        },
        {
            "id": 2,
            "question": "When would you nest a stack inside a tab?",
            "preferredAnswer": "When each tab has its own **detail flows**—e.g. Home tab pushes **ItemDetail** while Profile tab pushes **EditProfile**—keeping tab selection stable while stacks handle **depth**."
        },
        {
            "id": 3,
            "question": "What is a common pitfall when passing params between screens?",
            "preferredAnswer": "Passing **non-serializable** objects (functions, class instances) or **large blobs** in params—prefer **IDs** and refetch or use a store/cache."
        },
        {
            "id": 4,
            "question": "How does Android hardware back interact with stacks?",
            "preferredAnswer": "The stack should **pop** on back; misconfigured navigators can **exit the app** unexpectedly—test **back** on Android for each flow."
        },
        {
            "id": 5,
            "question": "What role does Link play in Expo Router?",
            "preferredAnswer": "**Link** provides **declarative navigation** with `href`, supporting **prefetch** patterns on web and consistent navigation on native when configured."
        }
    ]
