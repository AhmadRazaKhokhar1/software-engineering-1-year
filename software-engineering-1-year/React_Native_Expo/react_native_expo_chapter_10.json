    "ShortQuestions": [
        {
            "id": 1,
            "question": "Why use SecureStore instead of AsyncStorage for refresh tokens?",
            "preferredAnswer": "**SecureStore** uses **OS-backed** secure storage; **AsyncStorage** is **not** encrypted and is inappropriate for **high-value secrets**."
        },
        {
            "id": 2,
            "question": "What is prop drilling?",
            "preferredAnswer": "Passing props through **many intermediate** components that don’t use them—**Context** or state libraries reduce this."
        },
        {
            "id": 3,
            "question": "Why validate JSON shape from APIs?",
            "preferredAnswer": "Servers can change; **runtime validation** (zod/io-ts) prevents **crashes** from unexpected **nulls** or types."
        },
        {
            "id": 4,
            "question": "What does refetch-on-focus mean in TanStack Query?",
            "preferredAnswer": "When the app **returns active**, queries **refresh**—great for mobile where data **staleness** is common."
        },
        {
            "id": 5,
            "question": "Name one downside of putting everything in global state.",
            "preferredAnswer": "**Harder reasoning**, **unnecessary re-renders**, and **tighter coupling**—prefer **local** state when possible."
        }
    ]
