    "ShortQuestions": [
        {
            "id": 1,
            "question": "Why is ScrollView a poor choice for 5,000 rows?",
            "preferredAnswer": "**ScrollView** mounts **all** children up front—memory and layout cost explode. **FlatList** virtualizes."
        },
        {
            "id": 2,
            "question": "Why should keyExtractor keys be stable?",
            "preferredAnswer": "Unstable keys cause **wrong reuse** of rows, **state bugs**, and **janky** reordering when data updates."
        },
        {
            "id": 3,
            "question": "What role does windowSize play in FlatList?",
            "preferredAnswer": "It controls how many screen lengths of items stay mounted around the viewport—**higher** uses more memory, **lower** can increase mount churn."
        },
        {
            "id": 4,
            "question": "When is SectionList preferred over FlatList?",
            "preferredAnswer": "When data is **grouped** with **section headers** and possibly **sticky** headers—e.g. contacts alphabet sections."
        },
        {
            "id": 5,
            "question": "Name one symptom of an expensive renderItem.",
            "preferredAnswer": "**Dropped frames** when scrolling, **JS thread** spikes in perf overlay, or **battery** drain on long scrolls."
        }
    ]
}
