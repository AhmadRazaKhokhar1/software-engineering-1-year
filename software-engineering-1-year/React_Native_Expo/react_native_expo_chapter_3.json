    "ShortQuestions": [
        {
            "id": 1,
            "question": "Why type callback props like onSubmit: () => void instead of any?",
            "preferredAnswer": "Explicit function types document the contract, enable **autocomplete**, and let TypeScript catch **wrong arity** or **missing handlers** before runtime."
        },
        {
            "id": 2,
            "question": "What is the difference between ViewStyle and TextStyle?",
            "preferredAnswer": "**ViewStyle** styles layout containers (**View**, **Pressable**). **TextStyle** styles **Text** (font, lineHeight, etc.). Some props overlap (margin, padding) but text-specific props belong on **TextStyle**."
        },
        {
            "id": 3,
            "question": "Give one benefit of colocating types next to a component file.",
            "preferredAnswer": "Changes to props stay **local** and visible during refactors; importing screens get **accurate** typings without hunting a global types folder."
        },
        {
            "id": 4,
            "question": "When might you use useReducer instead of useState for form state?",
            "preferredAnswer": "When multiple fields update together with **complex transitions** or **shared validation** rules, a **reducer** centralizes updates and avoids a chain of interdependent **setState** calls."
        },
        {
            "id": 5,
            "question": "What does “thin screen, fat components” mean?",
            "preferredAnswer": "Screens orchestrate data and navigation; **reusable UI** lives in components. This keeps each file focused and **testable**."
        }
    ]
