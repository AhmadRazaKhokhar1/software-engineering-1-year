    "ShortQuestions": [
        {
            "id": 1,
            "question": "Why specify width/height or aspectRatio for remote images?",
            "preferredAnswer": "Without intrinsic sizing, layout **reflows** after decode causing **jumps**; RN needs **bounded** layout for images."
        },
        {
            "id": 2,
            "question": "What is the purpose of app icon and splash consistency?",
            "preferredAnswer": "**Brand recognition** and **trust**; mismatched splash vs in-app UI feels **unpolished** and confuses users during launch."
        },
        {
            "id": 3,
            "question": "When would you use a blurhash or placeholder?",
            "preferredAnswer": "For **slow networks**—shows **structured placeholder** color until the full image arrives, improving perceived performance."
        },
        {
            "id": 4,
            "question": "How does expo-google-fonts simplify fonts?",
            "preferredAnswer": "Prepackaged **font families** with **useFonts** integration—less manual **.ttf** copying for common open fonts."
        },
        {
            "id": 5,
            "question": "What happens if you forget to preload a custom font?",
            "preferredAnswer": "Text may render with **system fallback** first, then **snap** to custom font—**FOUT**; preload with **useFonts** or similar."
        }
    ]
