    "ShortQuestions": [
        {
            "id": 1,
            "question": "Why can keyboard handling differ between iOS and Android?",
            "preferredAnswer": "**OS keyboard behavior**, **window resizing**, and **vendor** differences mean `KeyboardAvoidingView` behavior and `behavior` prop choices vary—test both platforms."
        },
        {
            "id": 2,
            "question": "What is a ref used for with TextInput?",
            "preferredAnswer": "**Imperative methods**: `focus()`, `blur()`, `clear()`, measuring layout—bridging declarative React with **focus control**."
        },
        {
            "id": 3,
            "question": "Why show inline errors instead of only Alert.alert?",
            "preferredAnswer": "**Inline** errors are **contextual**, accessible, and don’t block interaction—users fix fields **faster**."
        },
        {
            "id": 4,
            "question": "When might you use a form library (e.g. react-hook-form) in RN?",
            "preferredAnswer": "Large forms with **validation schemas**, **dirty tracking**, and **performance** optimizations for controlled fields."
        },
        {
            "id": 5,
            "question": "What does keyboardVerticalOffset adjust?",
            "preferredAnswer": "Extra offset for **headers, tab bars**, or **custom** chrome so focused fields aren’t hidden under the keyboard."
        }
    ]
