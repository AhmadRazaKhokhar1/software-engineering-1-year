    "ShortQuestions": [
        {
            "id": 1,
            "question": "Why can OTA not replace every kind of change?",
            "preferredAnswer": "If you change **native code**, **permissions**, or **native modules**, users need a new **binary**—OTA updates **JS/assets** within the same native runtime compatibility."
        },
        {
            "id": 2,
            "question": "What is a preview profile used for?",
            "preferredAnswer": "**Internal testers** get non-production builds with **staging** API endpoints and **feature flags** without touching production users."
        },
        {
            "id": 3,
            "question": "Why track runtimeVersion with updates?",
            "preferredAnswer": "Ensures OTA bundles match the **native** runtime—prevents **crashes** from incompatible **JS** expecting different native modules."
        },
        {
            "id": 4,
            "question": "Name one artifact EAS Build might output for Android.",
            "preferredAnswer": "**AAB** for Play Store or **APK** for direct installs/sideload testing—depending on profile configuration."
        },
        {
            "id": 5,
            "question": "Why keep secrets off the client?",
            "preferredAnswer": "Client bundles are **inspectable**; attackers can extract keys—use **servers** to hold **private** credentials."
        }
    ]
