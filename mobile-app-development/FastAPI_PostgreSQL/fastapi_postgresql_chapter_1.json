        {
            "id": 1,
            "question": "Explain the difference between Path Parameters and Query Parameters with examples.",
            "preferredAnswer": "Path parameters are mandatory values embedded in the URL structure to identify a specific resource.\nExample: GET /users/123 identifies User ID 123.\n\nQuery parameters are optional filtering/search criteria appended after '?'.\nExample: GET /users?active=true filters active users.\nPath identifies 'Who', Query filters 'Which subset'."
        },
        {
            "id": 2,
            "question": "List three benefits of using FastAPI over Flask for a new project.",
            "preferredAnswer": "1. Native Async/Await support (async/await keywords built-in).\n2. Automatic Data Validation using Pydantic models (no manual checking).\n3. Automatic Interactive Documentation (Swagger UI) generated from code types without extra plugins."
        },
        {
            "id": 3,
            "question": "Write a FastAPI endpoint that returns a greeting message with a user name passed as a path parameter.",
            "preferredAnswer": "python\nfrom fastapi import FastAPI\n\napp = FastAPI()\n\n@app.get(\"/greet/{name}\")\ndef greet_user(name: str):\n    return {\"message\": f\"Hello, {name}!\"}\n\n\nThis creates a dynamic URL like /greet/Alice that automatically extracts 'Alice' into the function argument."
        },
        {
            "id": 4,
            "question": "What is the purpose of the '--reload' flag when starting Uvicorn?",
            "preferredAnswer": "The --reload flag enables auto-restart. If you modify any Python file in your project while the server is running, Uvicorn detects the change and automatically restarts the server process. This saves time during development because you don't need to stop/start manually after every change. Do not use in production."
        },
        {
            "id": 5,
            "question": "Why is 201 CREATED used instead of 200 OK for POST requests?",
            "preferredAnswer": "While 200 OK means the request was processed successfully, 201 specifically indicates that a NEW resource was created as a result. Clients may rely on the 201 status code to trigger different behaviors (like redirecting to the new resource URL) compared to a simple update which would remain 200."
        }
